  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.15.0",
