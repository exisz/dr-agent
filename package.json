{
  "name": "dr-agent",
  "version": "0.3.2",
  "description": "Doctor for AI agent codebases \u2014 catches common pitfalls before they cost you days",
  "type": "module",
  "bin": {
    "dr-agent": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
